# ClydeMemory Configuration
# Copy to .env and fill in your values, then: source .env

# User identity
CLYDE_USER=user

# Data directories
CLYDE_DATA_DIR=~/.clyde-memory
CLYDE_STATE_DIR=~/.clyde-memory/state
CLYDE_LOG_DIR=/var/log

# Claude Code project directories (colon-separated)
# Auto-detected if not set: ~/.claude/projects
CLYDE_CLAUDE_DIRS=~/.claude/projects

# Session markdown directory (for OpenClaw-style agents)
CLYDE_SESSION_MEMORY_DIR=~/.clyde-memory/sessions

# Agent type: "claude-code", "openclaw", or "auto"
CLYDE_AGENT_TYPE=auto

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...

# Database (Docker defaults — change for remote)
CLYDE_PG_HOST=127.0.0.1
CLYDE_PG_PORT=5432
CLYDE_PG_USER=clyde
CLYDE_PG_DB=clyde_memory
CLYDE_PG_PASSWORD=changeme

CLYDE_REDIS_HOST=127.0.0.1
CLYDE_REDIS_PORT=6379

CLYDE_QDRANT_HOST=localhost
CLYDE_QDRANT_PORT=6333

# Daemon socket
CLYDE_SOCK_PATH=/tmp/clyde-memo.sock

# Your named entities (pipe-separated) — these boost memory search scores
# when mentioned in prompts
CLYDE_USER_ENTITIES=myproject|myclient|myservice

# Custom topic patterns (JSON) — optional
# CLYDE_USER_TOPICS={"myapp": "myapp|my-app|myservice"}
